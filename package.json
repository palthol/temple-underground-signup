{
  "name": "temple-underground-signup",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:waiver": "npm --workspace apps/waiver-v2 run dev",
    "dev:api": "npm --workspace services/api run dev",
    "dev:dashboard": "npm --workspace apps/dashboard run dev",
    "dev:marketing": "npm --workspace apps/marketing run dev",
    "build": "npm-run-all build:*",
    "build:waiver": "npm --workspace apps/waiver-v2 run build",
    "build:dashboard": "npm --workspace apps/dashboard run build",
    "build:marketing": "npm --workspace apps/marketing run build",
    "test:marketing": "npm --workspace apps/marketing run test",
    "start": "npm --workspace services/api run start",
    "typecheck": "echo 'no types yet'",
    "lint": "echo 'no linter yet'",
    "supabase": "supabase",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:pull": "supabase db pull",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "supabase": "^2.75.5"
  },
  "dependencies": {
    "@uiw/react-signature": "^1.3.2"
  }
}
